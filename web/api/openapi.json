              "type": "string"
            }
          },
          {
            "name": "time",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "log (texto)",
            "content": {
              "text/plain": {}
            }
          }
        }
      }
    },
    "/contest/basic": {
      "get": {
        "tags": [
