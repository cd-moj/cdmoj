[Unit]
Description=MOJ judge worker %i (job-receiveitor + root-daemon; capability por instância)
Documentation=file:///home/ribas/moj/server/judge-gw/README.md
After=network.target
# SAMPLE / TEMPLATE. Instância = capability:port, ex.:
#   systemctl --user start moj-worker@pos:41050.service
#   systemctl --user start moj-worker@gpu:42000.service
# %i = "pos:41050" -> CAP=pos, PORT=41050.

[Service]
Type=simple
WorkingDirectory=%h/moj/judge/judge
Environment=MOJ_WORKER=%i
# Sobe o receptor TCP do worker (dispatch 'run'); o script certo por capability
# é job-receiveitor[-cm|-gpu|-hu].sh — o wrapper abaixo escolhe pela CAP.
ExecStart=/usr/bin/env bash -c '\
  CAP="${MOJ_WORKER%%:*}"; PORT="${MOJ_WORKER##*:}"; \
  case "$CAP" in cm) S=job-receiveitor-cm.sh;; gpu) S=job-receiveitor-gpu.sh;; \
                 hu) S=job-receiveitor-hu.sh;; *) S=job-receiveitor.sh;; esac; \
  RD=root-daemon.sh; [ "$CAP" = cm ] && RD=root-daemon-cm.sh; \
  [ "$CAP" = gpu ] && RD=root-daemon-gpu.sh; [ "$CAP" = hu ] && RD=root-daemon-hu.sh; \
  bash ~/server/judge-gw/register.sh up "$(hostname)" "$PORT" "$CAP"; \
  setsid bash "$RD" >/tmp/moj-rootd-$PORT.log 2>&1 & \
  ( while sleep 5; do St=free; flock -n /dev/shm/free-machine true || St=busy; \
      bash ~/server/judge-gw/register.sh beat "$(hostname)" "$PORT" "$CAP" "$St"; done ) & \
  exec socat TCP-LISTEN:$PORT,reuseaddr,fork EXEC:"bash $S"'
ExecStopPost=/usr/bin/env bash -c 'bash ~/server/judge-gw/register.sh down "$(hostname)" "${MOJ_WORKER##*:}"'
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
