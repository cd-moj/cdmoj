[Unit]
Description=MOJ judge master/escalonador (:27000 + escalonador por prioridade)
Documentation=file:///home/ribas/moj/cdmoj/server/judge-gw/README.md
After=network.target
# SAMPLE: roda os scripts vivos do cluster em judge/sistema_escalonador/.
# Hoje eles sobem via tmux/tcpserver (lancar-master.sh). Em ambientes SEM
# tcpserver, use socat/ncat como listener do master (ver README do judge-gw).

[Service]
Type=simple
WorkingDirectory=%h/moj/judge/sistema_escalonador
# Listener do master (dispatch 'run'/'getresult'). tcpserver é o original;
# alternativa portável com socat (descomente a que existir no host):
ExecStart=/usr/bin/env bash -c 'tcpserver -c 800 -H 0.0.0.0 27000 ./job-receiveitor-master.sh'
# ExecStart=/usr/bin/socat TCP-LISTEN:27000,reuseaddr,fork EXEC:'bash ./job-receiveitor-master.sh'
# O loop do escalonador (atribuição às filas) sobe em paralelo:
ExecStartPost=/usr/bin/env bash -c 'cd %h/moj/judge/sistema_escalonador && setsid bash escalonador.sh >/tmp/moj-escalonador.log 2>&1 &'
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
