# MOJ — corpo do vhost (estático + API + docs). Incluído pelos server blocks de PRODUÇÃO.
# TEMPLATE: gerado em /etc/nginx/snippets/moj-app.conf por `server/bin/install-nginx.sh`
# (substitui @WORKROOT@ e @ROUTER@). Não edite o gerado — edite este.
#
# @ROUTER@ = caminho do router.sh COMO O FCGIWRAP O ENXERGA:
#   - deploy podman (padrão): /opt/moj/cdmoj/server/api/v1/router.sh  (dentro da imagem!)
#   - bare-metal:             @WORKROOT@/cdmoj/server/api/v1/router.sh
# Apontar p/ o caminho do host num deploy em container = fcgiwrap não acha o script (502).

root   @WORKROOT@/cdmoj/web;
index  index.html;

# --- redirects de URLs do MOJ ANTIGO (links por aí em e-mails/favoritos/planilhas) --------
# /cgi-bin/index.sh era a home do CGI; /new/ era o prefixo da interface nova no site velho.
location = /cgi-bin/index.sh { return 301 /; }
location = /new  { return 301 /; }
location = /new/ { return 301 /; }
# problema legado: /new/treino/problem/?id=<org>.<slug> -> /treino/problema/?id=<org>%23<slug>
# (o map $moj_legacy_probid converte o 1º ponto em %23; id já canônico passa direto)
location /new/treino/problem/ {
    if ($moj_legacy_probid != "") { return 301 /treino/problema/?id=$moj_legacy_probid; }
    return 301 /treino/problema/?id=$arg_id;
}
# demais caminhos /new/<x> -> /<x> (a interface nova É a raiz agora)
location /new/ { rewrite ^/new/(.*)$ /$1 permanent; }
# Teto do CORPO da requisição. Quem manda no número é o `moj push`: ele serializa o pacote inteiro num
# JSON e os testes vão como STRING CRUA (não base64), então o corpo ≈ tamanho do pacote + ~10% de
# escape. Pacote de 500 MB ⇒ corpo de ~550 MB. (O `moj upload` manda tar.gz+base64 — 5-10× menor —, e
# para pacote gigante continua sendo o caminho mais barato.) Estourar isto é 413.
client_max_body_size  1000m;

# --- API: router.sh (bash) via fcgiwrap, num socket unix ---------------------------
location /api/v1/ {
    fastcgi_pass            unix:@WORKROOT@/run/fcgiwrap.sock;
    fastcgi_split_path_info ^(/api/v1)(/.*)$;
    fastcgi_param  SCRIPT_FILENAME   @ROUTER@;
    fastcgi_param  PATH_INFO         $fastcgi_path_info;
    fastcgi_param  REQUEST_METHOD    $request_method;
    fastcgi_param  QUERY_STRING      $query_string;
    fastcgi_param  CONTENT_TYPE      $content_type;
    fastcgi_param  CONTENT_LENGTH    $content_length;
    fastcgi_param  HTTP_AUTHORIZATION $http_authorization;
    fastcgi_param  HTTP_USER_AGENT    $http_user_agent;
    fastcgi_param  HTTP_X_FORWARDED_FOR $http_x_forwarded_for;
    fastcgi_param  HTTP_X_REAL_IP     $http_x_real_ip;
    fastcgi_param  REMOTE_ADDR       $remote_addr;
    fastcgi_param  SERVER_PROTOCOL   $server_protocol;
    fastcgi_param  GATEWAY_INTERFACE CGI/1.1;
    # Contest isolado quando o acesso vem por <id>.<host> — o $moj_contest_host vem do `map`
    # do conf.d/moj.conf e é VAZIO no site principal (o router.sh trata vazio como ausente).
    fastcgi_param  CONTEST_HOST      $moj_contest_host;
    # Rede de segurança, NÃO o conserto: um POST grande (pacote de problema) tem de terminar em
    # segundos (o handler não re-parseia mais o corpo N vezes). Se o nginx desiste, o processo do
    # handler NÃO morre junto — ele segue gravando, e o cliente fica sem saber se aplicou. Por isso
    # a folga: preferimos a resposta certa a um 504 com efeito indeterminado.
    fastcgi_read_timeout 300s;
}

# --- documentação (markdown cru) ---------------------------------------------------
location /docs/ { alias @WORKROOT@/cdmoj/docs/; autoindex on; }

# --- frontend estático (ESM, sem build) --------------------------------------------
location / { try_files $uri $uri/ =404; }
