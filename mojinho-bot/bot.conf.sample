# bot.conf.sample — configuração do mojinho-api.sh (TRANSPORTE FINO da API MOJ).
#
# COMO USAR:
#   cp bot.conf.sample bot.conf
#   chmod 600 bot.conf     # NÃO comite bot.conf
#
# "sourced" pelo bot (sintaxe bash). NÃO coloque segredos no .sample.
# O TOKEN DO TELEGRAM não fica aqui: vem só do arquivo ./token.
# O bot NÃO loga mais como .admin e NÃO tem lista GODS — ele autentica na API com um
# token DEDICADO (mojb_…) e toda a política/estado vive na API.

# --- Endpoint da API REST -------------------------------------------------
MOJ_API="http://127.0.0.1:8080/api/v1"
MOJ_HOST="moj.charge.naquadah.com.br"       # precisa bater com o server_name do vhost da API
MOJ_WEB="https://moj.charge.naquadah.com.br"  # base pública p/ os links de acesso nas respostas
MOJ_CONTEST="treino"

# --- Token do bot p/ a API (Bearer mojb_…) --------------------------------
# Segredo compartilhado bot<->API (require_bot). Gere com:
#   printf 'mojb_%s' "$(head -c24 /dev/urandom | base64 | tr -dc 'A-Za-z0-9' | head -c32)" \
#     > /home/ribas/moj/run/secrets/bot.token && chmod 600 /home/ribas/moj/run/secrets/bot.token
# O bot lê deste arquivo por padrão; ou defina BOT_TOKEN direto aqui.
BOT_TOKEN_FILE="/home/ribas/moj/run/secrets/bot.token"
# BOT_TOKEN="mojb_..."

# --- Alertas de incidente (a API decide o quê/quando; o bot só entrega) ----
# Chat de grupo (opcional) que recebe TODOS os alertas por broadcast, além das DMs
# aos .admin do treino com Telegram vinculado. Use o chat_id numérico do grupo.
ALERT_GROUP_CHAT=""       # ex.: -348168530
ALERT_POLL_SECS=25        # cadência do poll de alertas (= timeout do getUpdates)
