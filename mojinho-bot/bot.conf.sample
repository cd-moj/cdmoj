# bot.conf.sample — configuração do mojinho-api.sh (CLIENTE DA API MOJ).
#
# COMO USAR:
#   cp bot.conf.sample bot.conf
#   # edite bot.conf com as credenciais de admin reais (NÃO comite bot.conf)
#   chmod 600 bot.conf
#
# Este arquivo é "sourced" pelo bot (sintaxe bash). NÃO coloque segredos no
# .sample — apenas valores de exemplo/placeholder.
#
# O TOKEN DO TELEGRAM **não** fica aqui: ele vem só do arquivo ./token.

# --- Endpoint da API REST -------------------------------------------------
# Base da API v1. O bot roda no servidor e fala com a API local; o nginx roteia
# por Host, então MOJ_HOST precisa bater com o server_name do vhost da API.
MOJ_API="http://127.0.0.1:8080/api/v1"
MOJ_HOST="moj.charge.naquadah.com.br"

# Base pública (https) usada só para montar os LINKS de acesso nas respostas
# (ex.: "Acesse: $MOJ_WEB/new/treino/"). Pode diferir do MOJ_HOST interno.
MOJ_WEB="https://moj.charge.naquadah.com.br"

# --- Credenciais de admin que o bot usa para obter o token ----------------
# O bot loga via POST /auth/login?contest=$MOJ_ADMIN_CONTEST com estas credenciais
# e usa o token (Bearer) em todas as chamadas administrativas.
# O login DEVE terminar em ".admin" (convenção de papéis da API) e existir no
# passwd do contest indicado (CONTESTSDIR/$MOJ_ADMIN_CONTEST/passwd).
MOJ_ADMIN_CONTEST="treino"
MOJ_ADMIN_USER="bot.admin"
MOJ_ADMIN_PASS="TROQUE_ESTA_SENHA"

# --- Lista de GODS (admins do Telegram) -----------------------------------
# Usuários do Telegram autorizados a rodar os comandos administrativos do bot.
# Chave = username do Telegram (sem @); valor = true.
GODS[brunoribas]=true
